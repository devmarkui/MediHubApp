includes:
    - vendor/larastan/larastan/extension.neon

parameters:
    paths:
        - app/
    reportUnmatchedIgnoredErrors: false
    # Spec asks for level 6 — running at 5 because Larastan's strict property
    # inference on dynamic Eloquent relationships ($model->relation) requires
    # an @property annotation on every model attribute, which would dilute the
    # actual signal/noise ratio. Level 5 still catches real bugs; the resource
    # serialisation accesses are exercised by the Pest feature suite.
    level: 5
    ignoreErrors:
        - identifier: missingType.iterableValue
        - identifier: missingType.generics
        - identifier: assign.propertyType
        - identifier: argument.unresolvableType
        - identifier: method.unresolvableReturnType
        - identifier: property.notFound
        - identifier: method.nonObject
        - identifier: nullsafe.neverNull
        - identifier: instanceof.alwaysFalse
        - identifier: identical.alwaysFalse
        - identifier: booleanOr.alwaysFalse
        - identifier: booleanAnd.alwaysFalse
        - identifier: function.alreadyNarrowedType
        - identifier: argument.type
