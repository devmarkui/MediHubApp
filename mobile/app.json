{
  "expo": {
    "name": "MediHub",
    "slug": "medihub",
    "scheme": "medihub",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F766E"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "lk.markui.medihub",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "MediHub uses the camera so you can update your profile photo.",
        "NSPhotoLibraryUsageDescription": "MediHub uses your photo library so you can upload a profile photo."
      }
    },
    "android": {
      "package": "lk.markui.medihub",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F766E"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "NOTIFICATIONS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      "expo-notifications",
      "expo-localization",
      [
        "expo-image-picker",
        {
          "photosPermission": "MediHub uses your photo library so you can upload a profile photo."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      }
    }
  }
}
